#include <iostream>
using namespace std;

class Node {
public: 
	int data;     //ElemType data;
	Node* next; 
};

Node* initList()
{
	Node* head = new Node;    
	head->data = 0;
	head->next = nullptr;
	return head;
}

//Node* head = new Node(); 直接完成初始化

//单链表：头插法
void insertHead(Node* head ,int num)   // (Node* head , ElemType num)
{
	//默认head不为NULL
	Node* node = new Node;    //创建新的结点
	node->data = num;			//完成初始化
	node->next = head->next;     //挂载
	head->next = node;      
	return;
}

//单链表：遍历单链表
void  printList(Node* head)
{	
	//默认head不为NULL
	Node* node = head->next;
	while (node != NULL)
	{
		cout << node->data << endl;
		node = node->next;
	}
}

//单链表：尾插法
Node* insertTail(Node* tail , int num) //(Node* tail , ElemType num)
{	
	//默认tail不为NULL
	Node* node = new Node();   //初始化
	node->data = num;		//赋值
	tail->next = node;     //挂载
	return node;
}

//单链表：指定位置插入
void insertNode(Node* head, int pos , int num) //(Node* head, int pos, ElemType num )
{	
	//默认head不为NULL, (pos插入的位置是指头结点之后的整条链表具有的结点数)
	Node* p = head;
	int i = 0;
	while (i < pos-1) 
	{
		p = p->next;   //找到指定插入位置前的那个结点
		i++;
		if (p == NULL) { return; }
	}
	Node* node = new Node();   //初始化新结点
	node->data = num;		
	node->next = p->next;  //挂载
	p->next = node;
}

//单链表：指定位置删除
void deleteNode(Node* head , int pos)  //(Node* head, ElemType pos)
{	
	//默认head不为NULL
	Node* p = head;
	int i = 0;
	while (i < pos - 1)     
	{
		p = p->next;
		i++;
		if (p == NULL) { return; }  //判断pos大小是否合法
	}
	if (p->next == NULL) { cout << "要删除的位置错误" << endl; return; }  //判断要删除的节点是否存在
	Node* q = p->next;
	p->next = q->next;
	delete q;
	return;
}

//单链表：获取链表长度
int listLength(Node* head)
{
	Node* p = head;
	int length = 0;
	while (p->next != NULL)
	{
		length++;
		p = p->next;
	}
	return length;
}

//单链表：释放链表(释放链表中每个结点的内存)
void deleteList(Node* head) 
{
	Node* p = head->next;  //从第一个结点开始
	Node* q;
	while (p != NULL) 
	{
		q = p->next;
		delete p;
		p = q;
	}
	head->next = NULL; //更新头结点存储的地址
}
