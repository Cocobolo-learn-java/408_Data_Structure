#include <iostream>
using namespace std;

class SeqList {
public:
	//动态分配
	int* data;   //ElemType* data;
	int length;

};

//合并俩顺序表
SeqList* mergeList(SeqList& list1 , SeqList& list2){
	//计算所需空间容量
	int newSize = list1.length + list2.length;
	//创建对象完成成员属性的初始化
	SeqList* list = new SeqList();
	//初始化顺序表data容量大小
	list->data = new int[newSize];   // list->data = new ElemType[newSize]
	//初始化顺序表length大小
	list->length = newSize;
	int i = 0, j = 0, k = 0;
	//开始合并
	while (i < list1.length && j < list2.length) 
	{
		if (list1.data[i] > list2.data[j])
		{
		list->data[k++] = list2.data[j++];
		}
		else
		{
		list->data[k++] = list1.data[i++];
		}
	}
	//如果list1中还有元素
	while (i < list1.length) { list->data[k++] = list1.data[i++]; }
	//如果list2中还有元素
	while (j < list2.length) { list->data[k++] = list2.data[j++]; }
	return list;
}



